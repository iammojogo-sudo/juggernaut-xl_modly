      "hf_skip_prefixes": [],
      "params_schema": [
        {
          "id": "prompt",
          "label": "Prompt",
          "type": "string",
          "default": "",
          "tooltip": "Describe the desired edit. E.g. 'a warrior in armor, jungle background'."
        },
        {
          "id": "negative_prompt",
          "label": "Negative Prompt",
          "type": "string",
          "default": "",
          "tooltip": "Things to avoid."
        },
