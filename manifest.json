          "type": "number",
          "default": 0.7,
          "min": 0.0,
          "max": 1.0,
          "step": 0.05,
          "tooltip": "0 = no change, 1 = fully regenerate. 0.3-0.5 for subtle, 0.7-0.9 for major changes."
        },
        {
          "id": "num_inference_steps",
          "label": "Quality Steps",
          "type": "select",
          "default": 30,
          "options": [
            { "value": 15, "label": "15 (Fast)" },
            { "value": 30, "label": "30 (Balanced)" },
            { "value": 50, "label": "50 (High)" }
          ]
        },
        {
          "id": "guidance_scale",
          "label": "Guidance Scale",
          "type": "number",
          "default": 7.0,
          "min": 1.0,
          "max": 20.0,
          "step": 0.5
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "int",
          "default": -1,
          "min": -1,
          "max": 2147483647
        }
      ]
    },
